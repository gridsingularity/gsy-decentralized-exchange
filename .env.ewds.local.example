# Copy to .env.ewds.local and load it with:
# docker compose --env-file .env.ewds.local -f docker-compose.ewds.yml up --build
#
# This compose file runs a local DDHub Client Gateway against EWF-hosted EWC
# Digital Spine services. It does not run a local broker, local IAM chain, or
# local SSI hub.

# Enable EWDS transport for DEX read-path services when the full DEX overlay is used.
OFFCHAIN_STORAGE_TRANSPORT=ewds
EWDS_ENABLE_HANDLER=true

# EWF-hosted DDHub / IAM / EWC services.
EWDS_BROKER_BASE_URL=https://ddhub-ewc.energyweb.org
EWDS_CACHE_SERVER_URL=https://identitycache.energyweb.org/v1
EWDS_EVENT_SERVER_URL=https://identitycache.energyweb.org
EWDS_RPC_URL=https://rpc.energyweb.org/
EWDS_ENS_URL=https://rpc.energyweb.org/
EWDS_CHAIN_ID=246
EWDS_CHAIN_NAME=EWC
EWDS_PARENT_NAMESPACE=dsmb.apps.ddhub.energyweb.auth.ewc
EWDS_DID_REGISTRY_ADDRESS=0xE29672f34e92b56C9169f9D485fFc8b9A136BCE4
EWDS_MTLS_ENABLED=true

# Local Client Gateway runtime.
EWDS_GATEWAY_PLATFORM=linux/amd64
# Browser/UI access goes through the local proxy:
# - http://localhost:3009
# - http://localhost:3009/docs
# Keep EWDS_GATEWAY_URL as the Docker-internal API URL used by GSY services.
EWDS_GATEWAY_URL=http://ddhub-gateway-api:3333

# Select and configure the DDHub Client Gateway secrets engine according to
# the Energy Web deployment guide. The local gateway setup uses the bundled
# HashiCorp Vault service by default.
SECRETS_ENGINE=vault
VAULT_ENDPOINT=http://vault_demo:8200
# Leave empty for the bundled local Vault. The compose vault-init service writes
# the root token to a shared volume and the gateway containers load it at startup.
VAULT_TOKEN=

# Configure the DID/EWC wallet private key and upload EWF-provided mTLS
# material through the local gateway UI/API after the gateway starts.
# Do not commit .env.ewds.local or local certificate/private-key files.

# Topic contract defaults. These are for the future GSY-specific topic/channel
# setup after EWF creates or authorizes the required topics.
EWDS_REQUEST_FQCN=gsy.dex.offchain.request
EWDS_RESPONSE_FQCN=gsy.dex.offchain.response
EWDS_TOPIC_OWNER=dsmb.apps.ddhub.energyweb.auth.ewc
EWDS_ORDERS_REQUEST_TOPIC=orders.query
EWDS_ORDERS_RESPONSE_TOPIC=orders.query.response
EWDS_TRADES_REQUEST_TOPIC=trades.query
EWDS_TRADES_RESPONSE_TOPIC=trades.query.response
EWDS_MEASUREMENTS_REQUEST_TOPIC=measurements.query
EWDS_MEASUREMENTS_RESPONSE_TOPIC=measurements.query.response

# E2E tests still query orderbook HTTP APIs directly for assertions.
EWDS_ORDERBOOK_SERVICE_URL=http://gsy-orderbook:8080
